# Frontend Environment Variables
# Copy this file to .env

# Backend API endpoint URL (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Razorpay Test Key ID (Matches RAZORPAY_KEY_ID in backend .env)
# Get this from https://dashboard.razorpay.com/
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here
